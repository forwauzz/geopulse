{
  "$schema": "node_modules/wrangler/config-schema.json",
  // GEO-Pulse Cloudflare Workers configuration
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  // Stack: Next.js via @opennextjs/cloudflare
  // Worker gzip size: 3 MiB (Free) / 10 MiB (Paid) — see workers/platform/limits#worker-size

  // Local `wrangler deploy` / `wrangler dev`: runs before bundling.
  // Git-connected Workers Builds does NOT use this automatically.
  "build": {
    "command": "node scripts/opennext-build.cjs"
  },

  "name": "geo-pulse",
  "main": "workers/cloudflare-entry.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "geo-pulse"
    }
  ],

  // Non-sensitive config only.
  // Values in `vars` are part of the deployed Worker config and persist across deploys.
  // You do NOT need to re-add these after every push unless you want to change them.
  "vars": {
    "STRIPE_PRICE_ID_DEEP_AUDIT": "price_1TMFKSKknNpProh1qis5uGXF",
    "NEXT_PUBLIC_SUPABASE_URL": "https://vynrlgtxqnomxenakafn.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ5bnJsZ3R4cW5vbXhlbmFrYWZuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQzNjAwNzEsImV4cCI6MjA4OTkzNjA3MX0.mkPKKV8WL_uExFFtt_MWcAOV4Ens55Bysr3hAHLh2uM",
    "NEXT_PUBLIC_APP_URL": "https://getgeopulse.com/",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY": "0x4AAAAAACySl18X8egdbFEN",
    // OSS de-paywall flag. "false"/unset = full audit FREE for everyone (no Stripe); "true" = the
    // legacy paid ($29 deep audit) flow. getgeopulse.com is now free (OSS north star).
    "LEGACY_PAID_ENABLED": "false",
    "DISTRIBUTION_ENGINE_UI_ENABLED": "true",
    "DISTRIBUTION_ENGINE_WRITE_ENABLED": "true",
    "DISTRIBUTION_ENGINE_SOCIAL_OAUTH_ENABLED": "true",
    "DISTRIBUTION_ENGINE_BACKGROUND_ENABLED": "true",
    "DISTRIBUTION_ENGINE_DISPATCH_BATCH_LIMIT": "20",
    "GEMINI_MODEL": "gemini-2.5-flash-lite-preview-06-17",
    "GEMINI_ENDPOINT": "https://generativelanguage.googleapis.com/v1beta/models",

    // Benchmark execution defaults. API keys remain secrets.
    // "multi" routes by model id: gemini-* lanes to the Gemini adapter, gpt-* to OpenAI.
    // A lane whose secret is missing (e.g. PERPLEXITY_API_KEY) simply is not registered,
    // so its runs record as skipped rather than failing the sweep.
    "BENCHMARK_EXECUTION_PROVIDER": "multi",
    "BENCHMARK_EXECUTION_MODEL": "gemini-2.5-flash-lite",
    "BENCHMARK_EXECUTION_ENABLED_MODELS": "gemini-2.5-flash-lite",
    "BENCHMARK_EXECUTION_ENDPOINT": "https://generativelanguage.googleapis.com/v1beta/models",
    "OPENAI_MODEL": "gpt-4o-mini",

    // Startup rollout defaults (can be overridden per workspace in metadata rollout_flags).
    "STARTUP_DASHBOARD_ENABLED": "true",
    "STARTUP_GITHUB_AGENT_ENABLED": "true",
    "STARTUP_AUTO_PR_ENABLED": "true",
    "STARTUP_SLACK_AGENT_ENABLED": "true",
    "STARTUP_SLACK_AUTO_POST_ENABLED": "true",

    // GitHub App install entrypoint for startup connect flow (non-secret).
    "GITHUB_APP_INSTALL_URL": "https://github.com/apps/geo-pulse/installations/new",

    // Slack OAuth install entrypoint (non-secret).
    "STARTUP_SLACK_APP_INSTALL_URL": "https://slack.com/oauth/v2/authorize",
    "STARTUP_SLACK_CLIENT_ID": "10736716341730.10845478441990",

    // Vertical allowlist — benchmarking system is permitted to run these verticals
    // only. Currently law_firms (the live production lane) + marketing_firms
    // (seeded but not yet cut over). Set "*" to disable the lock.
    "BENCHMARK_VERTICAL_ALLOWLIST": "marketing_firms,law_firms",

    // Recurring benchmark lane config.
    // Currently pointing at the law_firms query set (live production). To cut
    // over to marketing_firms: seed the marketing query set
    //   npm run benchmark:seed:query-set -- --fixture eval/fixtures/benchmark-marketing-firms-v1-query-set.json
    // copy the printed UUID into QUERY_SET_ID below, and flip VERTICAL to "marketing_firms".
    "BENCHMARK_SCHEDULE_ENABLED": "true",
    "BENCHMARK_SCHEDULE_QUERY_SET_ID": "9910b5ac-ade6-42be-9dca-9b85c04e4469",
    // Comma-separated: each model is its own daily lane (domain × run-mode × model).
    // gpt-4o-mini needs the OPENAI_API_KEY secret set or its runs record as skipped.
    "BENCHMARK_SCHEDULE_MODEL_ID": "gemini-2.5-flash-lite,gpt-4o-mini",
    // blind_discovery first: it is the headline number (the prompt never names the target), and
    // putting it first means the cap can never starve it in favor of the assisted modes.
    "BENCHMARK_SCHEDULE_RUN_MODES": "blind_discovery,ungrounded_inference,grounded_site",
    // Empty = all schedule-enabled priority-1 domains, whatever their vertical; each domain can
    // carry its own question set via benchmark_domains.metadata.schedule_query_set_id.
    "BENCHMARK_SCHEDULE_VERTICAL": "",
    "BENCHMARK_SCHEDULE_SEED_PRIORITIES": "1",
    "BENCHMARK_SCHEDULE_DOMAINS": "",
    "BENCHMARK_SCHEDULE_DOMAIN_LIMIT": "20",
    // domains x 3 modes x 2 models, plus per-domain user-prompt sets where they exist.
    "BENCHMARK_SCHEDULE_MAX_RUNS": "160",
    "BENCHMARK_SCHEDULE_MAX_FAILURES": "5",
    "BENCHMARK_SCHEDULE_WINDOW_HOURS": "12",
    "BENCHMARK_SCHEDULE_VERSION": "v1",

    // Daily benchmark recap email.
    // Fires once a day at HOUR_LOCAL in the configured TIMEZONE (DST-aware via
    // Intl.DateTimeFormat). The worker cron triggers cover both EST and EDT
    // UTC offsets for America/Toronto. Leave _TO empty to disable. Requires
    // RESEND_API_KEY + RESEND_FROM_EMAIL to actually send.
    "BENCHMARK_DAILY_RECAP_TO": "uzzielt@techehealthservices.com",
    "BENCHMARK_DAILY_RECAP_HOUR_LOCAL": "19",
    "BENCHMARK_DAILY_RECAP_TIMEZONE": "America/Toronto",

    "DEEP_AUDIT_R2_PUBLIC_BASE": "https://pub-5b90c5727ac1429a93a0ffef23cf25f7.r2.dev",
    "DEEP_AUDIT_DEFAULT_PAGE_LIMIT": "1000",
    "DEEP_AUDIT_BROWSER_RENDER_MODE": "auto",
    // Report rewrite now runs on Cloudflare Workers AI (free tier, open-source model) instead of
    // the stale Gemini preview model that was returning HTTP 400. Set provider back to "gemini"
    // (and a valid GEMINI model id) to A/B against the paid path.
    "DEEP_AUDIT_INTERNAL_REWRITE_ENABLED": "true",
    "DEEP_AUDIT_INTERNAL_REWRITE_PROVIDER": "workers_ai",
    "DEEP_AUDIT_INTERNAL_REWRITE_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",

    "RESEND_FROM_EMAIL": "reports@getgeopulse.com",

    // Loop 5a — autonomous self-improvement (getgeopulse.com audits itself daily → emails the
    // plan). OFF by default: the daily audit runs only when SELF_IMPROVEMENT_ENABLED is truthy
    // AND self_improvement_settings.enabled is true in the DB AND a recipient is set AND the DB
    // kill switch is off. Flip ENABLED to "true" (and toggle the DB row) to turn it on.
    // SELF_IMPROVEMENT_TRIGGER_SECRET is a SECRET (wrangler secret put), not set here.
    // Learning loop armed: env ON. Still requires self_improvement_settings.enabled=true in the DB
    // (toggle in /admin/automation) before anything runs — so this is safe. autonomous_ship stays
    // a separate DB flag + external runtime.
    "SELF_IMPROVEMENT_ENABLED": "true",
    "SELF_IMPROVEMENT_TARGET_URL": "https://getgeopulse.com/",
    "SELF_IMPROVEMENT_HOUR_UTC": "12",
    "SELF_IMPROVEMENT_REPORT_TO": "tamonuzziel@gmail.com",

    // Loop 5b — autonomous marketing autopilot. Proposes review-gated content briefs for weak
    // (uncovered) topics once/day; NEVER publishes. OFF by default. Actually posting to social
    // needs a CONNECTED distribution account (channel/tool access) — the remaining blocker.
    // MARKETING_AUTOPILOT_TRIGGER_SECRET is a SECRET (wrangler secret put), not set here.
    "MARKETING_AUTOPILOT_ENABLED": "",
    "MARKETING_AUTOPILOT_DAILY_CAP": "2",
    "MARKETING_AUTOPILOT_HOUR_UTC": "13",

    // Admin Automation console (Loop 5 toggles). Capability flag: shows the /admin/automation
    // page + nav for platform admins. On for getgeopulse; leave empty in OSS forks to hide it.
    "AUTOMATION_CONSOLE_ENABLED": "true",

    // GEO Performance Monitoring scheduled sweep.
    // Runtime defaults live here; provider API keys remain secrets.
    "GPM_SCHEDULE_ENABLED": "true",
    // Platform feature flag: only these platforms run. Gemini + ChatGPT have keys
    // (OPENAI_API_KEY secret). To add Perplexity: add PERPLEXITY_API_KEY and append it here.
    "GPM_ENABLED_PLATFORMS": "gemini,chatgpt",
    "GPM_CHATGPT_MODEL_ID": "gpt-4o-mini",
    // Must be one of BENCHMARK_EXECUTION_ENABLED_MODELS or the Gemini adapter skips the
    // run as "model lane not enabled". Aligned with the benchmark lane model.
    "GPM_GEMINI_MODEL_ID": "gemini-2.5-flash-lite",
    "GPM_PERPLEXITY_MODEL_ID": "llama-3.1-sonar-small-128k-online",
    "GPM_NARRATIVE_MODEL": "claude-haiku-4-5-20251001",
    // Gemini fallback for the report narrative when no ANTHROPIC_API_KEY is set.
    "GPM_NARRATIVE_GEMINI_MODEL": "gemini-2.5-flash-lite",
    "GPM_PROMPT_BUILDER_MODEL": "claude-haiku-4-5-20251001",
    "GPM_REPORT_R2_PUBLIC_BASE": "https://pub-5b90c5727ac1429a93a0ffef23cf25f7.r2.dev",

    // Optional destination/provider defaults.
    "GHOST_ADMIN_API_VERSION": "v6.0"
  },

  // Cloudflare Workers AI — free-tier, open-source models used as the in-house "brain"
  // (report rewrite, user agents). No API key: it's a native binding on this account.
  // "remote" is not a choice: AI models have no local simulation and always run on Cloudflare, so
  // `wrangler dev` needs an account login. Stating it here is what the docs ask for; setting it to
  // false is an error. This is why CI skips the wrangler dev session (see next.config.ts).
  "ai": {
    "binding": "AI",
    "remote": true
  },

  "r2_buckets": [
    {
      "binding": "REPORT_FILES",
      "bucket_name": "geo-pulse-deep-audit-reports"
    }
  ],

  // Secrets are stored separately from code and persist across deploys.
  // If set in the Cloudflare dashboard or via `wrangler secret put`, you do NOT need to re-add them on every deploy.
  // Required core secrets:
  //   SUPABASE_SERVICE_ROLE_KEY
  //   STRIPE_SECRET_KEY
  //   STRIPE_WEBHOOK_SECRET
  //   GEMINI_API_KEY
  //   RESEND_API_KEY
  //   TURNSTILE_SECRET_KEY
  //   STARTUP_SLACK_CLIENT_ID
  //   STARTUP_SLACK_CLIENT_SECRET
  //   STARTUP_SLACK_SIGNING_SECRET
  //
  // Subscription billing (BILL stream — self-serve bundle subscriptions):
  //   No new secrets required. The existing STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET cover
  //   POST /api/billing/subscribe and the extended webhook handler.
  //
  //   Stripe price IDs for paid bundles (startup_dev, agency_core, agency_pro) are stored
  //   in the `service_bundles` DB table (columns: stripe_price_id, monthly_price_cents,
  //   trial_period_days) — NOT as env vars. Seed them via the admin console:
  //     /dashboard/services → Set Bundle Service Control → stripe_price_id + monthly_price_cents
  //
  //   New Stripe webhook events to register in the Stripe dashboard:
  //     customer.subscription.created
  //     customer.subscription.updated
  //     customer.subscription.deleted
  //     customer.subscription.trial_will_end
  //     invoice.payment_succeeded
  //     invoice.payment_failed
  //
  //   DB migration to apply on Supabase before first subscription:
  //     supabase/migrations/033_subscription_billing_foundation.sql
  //
  // Benchmark secret:
  //   BENCHMARK_EXECUTION_API_KEY
  //   Optional if benchmark execution should not fall back to GEMINI_API_KEY.
  //
  // GEO Performance Monitoring secrets:
  //   OPENAI_API_KEY
  //   PERPLEXITY_API_KEY
  //   ANTHROPIC_API_KEY
  //   RESEND_API_KEY
  // Without these, GPM can deploy but ChatGPT / Perplexity / narrative / email delivery will fail.
  //
  // Optional feature secrets:
  //   KIT_API_KEY
  //   BUTTONDOWN_API_KEY
  //   GHOST_ADMIN_API_URL
  //   GHOST_ADMIN_API_KEY
  //   X_ACCESS_TOKEN
  //   LINKEDIN_ACCESS_TOKEN
  //   LINKEDIN_AUTHOR_URN
  //   X_OAUTH_CLIENT_ID
  //   X_OAUTH_CLIENT_SECRET
  //   X_OAUTH_SCOPE
  //   X_OAUTH_AUTH_URL
  //   X_OAUTH_TOKEN_URL
  //   LINKEDIN_OAUTH_CLIENT_ID
  //   LINKEDIN_OAUTH_CLIENT_SECRET
  //   LINKEDIN_OAUTH_SCOPE
  //   LINKEDIN_OAUTH_AUTH_URL
  //   LINKEDIN_OAUTH_TOKEN_URL
  //   Optional provider base-url overrides:
  //   X_API_BASE_URL
  //   LINKEDIN_API_BASE_URL
  //   RECONCILE_SECRET
  //   BROWSER_RENDERING_API_TOKEN
  //   CLOUDFLARE_ACCOUNT_ID

  "kv_namespaces": [
    {
      "binding": "SCAN_CACHE",
      "id": "670fa578cf3b430687683445aac48eea",
      "preview_id": "f1c7e4c68ddc464ab3bcf0517206611f"
    }
  ],

  "queues": {
    "producers": [
      {
        "binding": "SCAN_QUEUE",
        "queue": "geo-pulse-scan-queue"
      },
      {
        "binding": "DISTRIBUTION_QUEUE",
        "queue": "geo-pulse-distribution-queue"
      }
    ],
    "consumers": [
      {
        "queue": "geo-pulse-scan-queue",
        "max_batch_size": 5,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "geo-pulse-dlq"
      },
      {
        "queue": "geo-pulse-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 1
      },
      {
        "queue": "geo-pulse-distribution-queue",
        "max_batch_size": 5,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "geo-pulse-distribution-dlq"
      },
      {
        "queue": "geo-pulse-distribution-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 1
      }
    ]
  },

  "unsafe": {
    "bindings": [
      {
        "name": "RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": {
          "limit": 10,
          "period": 60
        }
      }
    ]
  },

  "triggers": {
    // 00:00, 12:00, and 23:00 UTC. The 23:00 tick covers 7pm Toronto in EDT
    // (summer); the 00:00 tick covers 7pm Toronto in EST (winter). The recap
    // dispatch in workers/cloudflare-entry.ts gates on Toronto local hour so
    // exactly one recap fires per day regardless of DST. Benchmark schedule
    // sweeps dedup via schedule_run_key, so the extra tick is a no-op for them.
    // Hourly: enables hourly outreach/recurring cadences. Every scheduled job self-gates
    // (next_run_at, window keys, or an hour check), so extra ticks are cheap no-ops.
    "crons": ["0 * * * *"]
  },

  "observability": {
    "enabled": true
  }
}
