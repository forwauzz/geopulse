{
  "$schema": "node_modules/wrangler/config-schema.json",
  // GEO-Pulse — Cloudflare Workers configuration
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  // Stack: Next.js 15 via @opennextjs/cloudflare (NOT @cloudflare/next-on-pages — deprecated)

  // Local `wrangler deploy` / `wrangler dev`: runs before bundling. Git-connected Workers Builds does NOT use this — set dashboard Build to `npm run build:worker` or Deploy to `npm run deploy` (see PLAYBOOK/cloudflare-workers-builds.md).
  "build": {
    "command": "npx opennextjs-cloudflare build"
  },

  "name": "geo-pulse",
  "main": "workers/cloudflare-entry.ts",
  "compatibility_date": "2025-04-01", // Required for process.env population with OpenNext
  "compatibility_flags": ["nodejs_compat"], // Required for Supabase client + pdf-lib

  // Required by @opennextjs/cloudflare — without this, /_next/static/* returns HTML and CSS/JS MIME errors
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "geo-pulse"
    }
  ],

  // Non-sensitive config only — secrets go via `wrangler secret put`
  "vars": {
    "STRIPE_PRICE_ID_DEEP_AUDIT": "price_1TEi0JKknNpProh1sKThObxl",
    "NEXT_PUBLIC_SUPABASE_URL": "https://vynrlgtxqnomxenakafn.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "your-anon-key-here",
    "NEXT_PUBLIC_APP_URL": "https://geopulse.io",
    // Set in Worker dashboard or Workers Builds env — never use a fake key (Turnstile 400020).
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY": "",
    "GEMINI_MODEL": "gemini-2.5-flash-lite-preview-06-17",
    "GEMINI_ENDPOINT": "https://generativelanguage.googleapis.com/v1beta/models",
    // Public R2.dev base for deep-audit PDF/MD links (not a secret). Override in .dev.vars locally if needed.
    "DEEP_AUDIT_R2_PUBLIC_BASE": "https://pub-5b90c5727ac1429a93a0ffef23cf25f7.r2.dev"
  },

  // R2 — deep-audit PDF + Markdown (DA-003). Bucket must exist; public URL must match DEEP_AUDIT_R2_PUBLIC_BASE.
  "r2_buckets": [
    {
      "binding": "REPORT_FILES",
      "bucket_name": "geo-pulse-deep-audit-reports"
    }
  ],

  // Secrets — set via: wrangler secret put SECRET_NAME
  // Required secrets (never put these in this file):
  //   SUPABASE_SERVICE_ROLE_KEY
  //   STRIPE_SECRET_KEY
  //   STRIPE_WEBHOOK_SECRET
  //   GEMINI_API_KEY
  //   RESEND_API_KEY
  //   TURNSTILE_SECRET_KEY
  //   RECONCILE_SECRET (optional — admin reconcile endpoint)

  // KV Namespaces
  "kv_namespaces": [
    {
      "binding": "SCAN_CACHE",
      "id": "670fa578cf3b430687683445aac48eea",
      "preview_id": "f1c7e4c68ddc464ab3bcf0517206611f"
    }
  ],

  // Cloudflare Queues (free: 10,000 ops/day — verify in dashboard, added early 2026)
  "queues": {
    "producers": [
      {
        "binding": "SCAN_QUEUE",
        "queue": "geo-pulse-scan-queue"
      }
    ],
    "consumers": [
      {
        "queue": "geo-pulse-scan-queue",
        "max_batch_size": 5,
        "max_batch_timeout": 30,
        "max_retries": 3,
        "dead_letter_queue": "geo-pulse-dlq"
      },
      {
        "queue": "geo-pulse-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 1
      }
    ]
  },

  // Rate Limiting (free tier)
  "unsafe": {
    "bindings": [
      {
        "name": "RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": {
          "limit": 10,
          "period": 60
        }
      }
    ]
  },

  // Daily ping — keeps Supabase free-tier project from pausing after 7 days idle (see agents/DATABASE.md)
  "triggers": {
    "crons": ["0 12 * * *"]
  },

  // Observability
  "observability": {
    "enabled": true
  }
}
