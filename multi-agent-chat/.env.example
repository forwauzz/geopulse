# Copy this file to .env and fill in your keys.
# You only need the keys for providers you actually use.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Optional — add these to unlock more agents
GROQ_API_KEY=gsk_...       # groq.com — free tier, very fast LLaMA/Mixtral models
MISTRAL_API_KEY=...        # mistral.ai — European models, strong reasoning
