# Copy to `.env.local` (gitignored) for `npm run dev`.
# Next.js does not load `.dev.vars` — that file is for Wrangler (`npm run preview` / `wrangler dev`).

# Cloudflare Turnstile — test keys (always pass). Production: use real keys from the Turnstile dashboard.
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Add other server secrets here for local API routes if needed (same names as .dev.vars.example):
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
# STARTUP_SLACK_SIGNING_SECRET=
# STARTUP_SLACK_CLIENT_ID=
# STARTUP_SLACK_CLIENT_SECRET=
# DEEP_AUDIT_BROWSER_RENDER_MODE=off
# BROWSER_RENDERING_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# DISTRIBUTION_ENGINE_UI_ENABLED=false
# DISTRIBUTION_ENGINE_WRITE_ENABLED=false
# DISTRIBUTION_ENGINE_SOCIAL_OAUTH_ENABLED=false
# DISTRIBUTION_ENGINE_BACKGROUND_ENABLED=false
# DISTRIBUTION_ENGINE_DISPATCH_BATCH_LIMIT=20
# Optional text-first social adapter credentials (distribution slice 1B):
# X_ACCESS_TOKEN=
# X_API_BASE_URL=https://api.x.com
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:person:xxxxxxxx
# LINKEDIN_API_BASE_URL=https://api.linkedin.com
# Optional OAuth connect credentials (distribution slice 2A):
# X_OAUTH_CLIENT_ID=
# X_OAUTH_CLIENT_SECRET=
# X_OAUTH_SCOPE=tweet.read tweet.write users.read offline.access
# X_OAUTH_AUTH_URL=https://twitter.com/i/oauth2/authorize
# X_OAUTH_TOKEN_URL=https://api.x.com/2/oauth2/token
# LINKEDIN_OAUTH_CLIENT_ID=
# LINKEDIN_OAUTH_CLIENT_SECRET=
# LINKEDIN_OAUTH_SCOPE=openid profile w_member_social
# LINKEDIN_OAUTH_AUTH_URL=https://www.linkedin.com/oauth/v2/authorization
# LINKEDIN_OAUTH_TOKEN_URL=https://www.linkedin.com/oauth/v2/accessToken
#
# Admin-only dashboard access is DB-backed only:
# add the user to `platform_admin_users` through `/admin/admins`.
#
# Admin password sign-in (/admin/login): enable Email "password" in Supabase Auth settings,
# then add the user to `platform_admin_users` after the account exists.
# Customers continue to use magic link only on /login.
#
# Report eval smoke (npm run eval:smoke) — inserts one row into report_eval_runs (service role):
# Uses the same keys as Workers when writing to Supabase from local tooling.

