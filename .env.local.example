# Copy to `.env.local` (gitignored) for `npm run dev`.
# Next.js does not load `.dev.vars` — that file is for Wrangler (`npm run preview` / `wrangler dev`).

# Cloudflare Turnstile — test keys (always pass). Production: use real keys from the Turnstile dashboard.
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Add other server secrets here for local API routes if needed (same names as .dev.vars.example):
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
