{
  "name": "geo-pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "node scripts/opennext-build.cjs",
    "cf:queues:check": "node scripts/check-cloudflare-queues.cjs",
    "deploy:guard": "npm run cf:queues:check",
    "deploy:upload": "npm run deploy:guard && wrangler versions upload",
    "deploy": "npm run deploy:guard && node scripts/opennext-build.cjs && wrangler deploy",
    "preview": "node scripts/opennext-build.cjs && wrangler dev",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > lib/supabase/database.types.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "eval:smoke": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/report-eval-smoke.ts",
    "eval:promptfoo": "npm run eval:promptfoo:report && npm run eval:promptfoo:retrieval",
    "eval:promptfoo:report": "node ./scripts/run-promptfoo.cjs eval -c eval/promptfoo/promptfooconfig.report.yaml --no-progress-bar",
    "eval:promptfoo:retrieval": "node ./scripts/run-promptfoo.cjs eval -c eval/promptfoo/promptfooconfig.retrieval.yaml --no-progress-bar",
    "eval:promptfoo:write:report": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/promptfoo-eval-write.ts --framework promptfoo_report",
    "eval:promptfoo:write:retrieval": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/promptfoo-eval-write.ts --framework promptfoo_retrieval",
    "eval:retrieval:write": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/retrieval-eval-write.ts",
    "benchmark:seed": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-seed.ts",
    "benchmark:seed:domains": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-seed-domains.ts",
    "benchmark:seed:query-set": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-seed-query-set.ts",
    "benchmark:seed:query-set:business-counsel": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-seed-query-set.ts --fixture eval/fixtures/benchmark-law-firms-business-counsel-v1-query-set.json",
    "benchmark:schedule:preview": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-preview.ts",
    "benchmark:schedule:capacity": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-capacity.ts",
    "benchmark:schedule:health": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-health.ts",
    "benchmark:schedule:run-now": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-run-now.ts",
    "benchmark:schedule:summary": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-summary.ts",
    "benchmark:schedule:outliers": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-outliers.ts",
    "benchmark:schedule:recurrence": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-schedule-recurrence.ts",
    "benchmark:run:diagnostic": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-run-diagnostic.ts",
    "benchmark:run": "node --env-file-if-exists=.env.local --env-file-if-exists=.dev.vars ./node_modules/tsx/dist/cli.mjs scripts/benchmark-runner.ts",
    "report:layer-one:rewrite-prompt": "node ./node_modules/tsx/dist/cli.mjs scripts/layer-one-report-rewrite-prompt.ts"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.1.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tailwindcss/typography": "^0.5.0",
    "next": "^15.3.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "promptfoo": "^0.121.3",
    "supabase": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1",
    "wrangler": "^4.10.0"
  },
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "overrides": {
    "esbuild": "0.27.4",
    "cloudflare": "4.4.1"
  }
}
