# GEO-Pulse — Local Development Secrets
# Copy this file to .dev.vars and fill in real values
# .dev.vars is in .gitignore — NEVER commit it
# These mirror the secrets set via `wrangler secret put` for production
#
# --- `next dev` vs Wrangler ---
# `npm run dev` (Next.js only) loads server env from `.env.local`, NOT from `.dev.vars`.
# If POST /api/scan returns 503 or turnstile/db errors, add the same server secrets to
# `.env.local` (gitignored): SUPABASE_SERVICE_ROLE_KEY, TURNSTILE_SECRET_KEY, GEMINI_API_KEY,
# plus NEXT_PUBLIC_* lines as needed. Or use `npm run preview` so Wrangler injects `.dev.vars`.
# Quick start for `next dev`: copy `.env.local.example` → `.env.local` (Turnstile test keys included).

# Supabase — use project API settings page
# anon key is safe to expose client-side; service_role is NOT
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
#
# Admin password sign-in uses the same Supabase project: enable Email "password" in Auth settings
# and add the user to `platform_admin_users` through `/admin/admins` after the account exists.
# Optional: npm run eval:smoke (inserts report_eval_runs) uses NEXT_PUBLIC_SUPABASE_URL + this key from .env.local

# Stripe — use test mode keys during development (sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Price ID for deep audit ($29 prod or $1 test price in Stripe Dashboard → Products)
STRIPE_PRICE_ID_DEEP_AUDIT=price_your_price_id
# Get the webhook secret from: stripe listen --forward-to localhost:8787/api/webhooks/stripe
# (use the port shown by `npm run preview` / `wrangler dev` — queue + webhook need the Worker)

# Optional: POST /api/admin/reconcile-deep-audit (header x-reconcile-secret) to backfill payments + PDF queue
# for paid Checkout sessions that never created a `payments` row (e.g. webhook URL wrong or offline).
RECONCILE_SECRET=

# Google Gemini API
# Free tier: 1,000 req/day (Gemini 2.5 Flash-Lite)
# Get key: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: internal benchmark execution lane. Defaults to stub unless enabled.
# BENCHMARK_EXECUTION_PROVIDER=gemini
# BENCHMARK_EXECUTION_API_KEY=your-benchmark-api-key-here
# BENCHMARK_EXECUTION_MODEL=gemini-2.0-flash
# BENCHMARK_EXECUTION_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models

# Resend — transactional email
# Get key: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# Verified sender (domain or onboarding@resend.dev for tests)
RESEND_FROM_EMAIL=GEO-Pulse <onboarding@resend.dev>

# Cloudflare Turnstile — CAPTCHA
# Use always-pass test key for local dev: 1x0000000000000000000000000000000AA
# Get real keys: https://developers.cloudflare.com/turnstile/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# DEEP_AUDIT_R2_PUBLIC_BASE — single source of truth is wrangler.jsonc [vars]. Set here only to override local Wrangler.
# DEEP_AUDIT_R2_PUBLIC_BASE=https://pub-xxxxx.r2.dev

# Default page count for new paid deep audits (1–1000). Plaintext; mirrors wrangler.jsonc DEEP_AUDIT_DEFAULT_PAGE_LIMIT.
# DEEP_AUDIT_DEFAULT_PAGE_LIMIT=10

# Optional: paid deep-audit SPA rendering via Cloudflare Browser Rendering REST API.
# Disabled by default. Valid modes: off | auto | force
# - off: never use browser rendering
# - auto: render only likely SPA-shell pages during deep audits
# - force: render every deep-audit page (higher cost)
# Requires a Browser Rendering API token and your Cloudflare account id.
# DEEP_AUDIT_BROWSER_RENDER_MODE=off
# BROWSER_RENDERING_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Weekly marketing attribution report — email recipient (opt-in).
# If set, the Monday cron sends a funnel + conversion summary via Resend.
# MARKETING_REPORT_TO=uzzielt@techehealthservices.com

# Admin-only dashboard access is DB-backed only.
# Add the user to `platform_admin_users` through `/admin/admins`.
# The app no longer reads an `ADMIN_EMAIL` fallback.

# ============================================================
# NON-SECRET CONFIG (also in wrangler.jsonc [vars] for production)
# These are duplicated here for local dev convenience
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://vynrlgtxqnomxenakafn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Magic link auth: add redirect URL in Supabase Dashboard → Auth → URL configuration:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
# Must match the origin you use in the browser (Stripe redirects here after checkout).
# next dev: http://localhost:3000
# wrangler preview / npm run preview: use the URL Wrangler prints, e.g. http://127.0.0.1:8787
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8787
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
