# Local-only runtime values (copy to .dev.vars and fill real values)
# .dev.vars is ignored by git. Do not commit secrets.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_DEEP_AUDIT=price_xxx

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite-preview-06-17
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models

RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=reports@mail.example.com

MARKETING_INGEST_KEY=replace-with-random-long-secret
